modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Noxe Editor"

[[workflows.workflow]]
name = "Run Noxe Editor"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "make && ./bin/noxe"

[workflows.workflow.metadata]
outputType = "console"
